import React, { useState, useEffect } from "react";
import "./DeliveryForm.css";
import "./CustomerForm.css";

function GenerateBill() {
  const [customers, setCustomers] = useState([]);
  const [selectedCustomer, setSelectedCustomer] = useState("");
  const [startDate, setStartDate] = useState("");
  const [endDate, setEndDate] = useState("");
  const [billData, setBillData] = useState(null);
  const [editableCosts, setEditableCosts] = useState({});

  useEffect(() => {
    fetchCustomers();
  }, []);

  const fetchCustomers = async () => {
    try {
      const response = await fetch('https://script.google.com/macros/s/AKfycbx6LjlqjkAFmENEyhI6P-O3I7j3vLfgnGW5Gug8y0r6TDshBQhywAleC-No9rdh2Dnhlw/exec?action=getCustomers');
      const result = await response.json();
      if (result.success) {
        setCustomers(result.data || []);
      }
    } catch (error) {
      console.error('Error fetching customers:', error);
    }
  };

  const handleGenerateBill = async (e) => {
    e.preventDefault();
    try {
      const response = await fetch(`https://script.google.com/macros/s/AKfycbwTUNL79Ei0wLkyhnK2EpiA-DamX3nhTqKHWQy4DZWW1Hml061D-004Vq3TeM_0bPi4/exec?action=generateBill&customer=${encodeURIComponent(selectedCustomer)}&startDate=${startDate}&endDate=${endDate}`);
      const result = await response.json();
      
      if (result.success) {
        setBillData(result.data);
        // Initialize editable costs
        const costs = {};
        result.data.items?.forEach((dc, dcIndex) => {
          dc.cylinders.forEach((cyl, cylIndex) => {
            costs[`${dcIndex}-${cylIndex}`] = cyl.cost;
          });
        });
        setEditableCosts(costs);
      } else {
        alert(`Failed: ${result.error || 'Unknown error'}`);
      }
    } catch (error) {
      console.error('Error:', error);
      alert(`Error generating bill: ${error.message}`);
    }
  };

  const handleCostChange = (dcIndex, cylIndex, newCost) => {
    setEditableCosts({
      ...editableCosts,
      [`${dcIndex}-${cylIndex}`]: parseFloat(newCost) || 0
    });
  };

  const calculateTotal = () => {
    return Object.values(editableCosts).reduce((sum, cost) => sum + cost, 0).toFixed(2);
  };

  const handlePrint = () => {
    window.print();
  };

  return (
    <div className="customer-container" style={{ maxWidth: '800px' }}>
      <div className="customer-form-card">
        <h2 className="customer-form-title">Generate Bill</h2>

        <form onSubmit={handleGenerateBill}>
          <div className="input-group">
            <label>Select Customer *</label>
            <select 
              value={selectedCustomer} 
              onChange={(e) => setSelectedCustomer(e.target.value)}
              required
            >
              <option value="">Choose a customer</option>
              {customers.map((customer, index) => (
                <option key={index} value={customer.name}>
                  {customer.name}
                </option>
              ))}
            </select>
          </div>

          <div className="input-group">
            <label>Start Date *</label>
            <input 
              type="date" 
              value={startDate}
              onChange={(e) => setStartDate(e.target.value)}
              required
            />
          </div>

          <div className="input-group">
            <label>End Date *</label>
            <input 
              type="date" 
              value={endDate}
              onChange={(e) => setEndDate(e.target.value)}
              required
            />
          </div>

          <button type="submit">Generate Bill</button>
        </form>

        {billData && (
          <div style={{ marginTop: '30px', padding: '20px', border: '2px solid #667eea', borderRadius: '8px' }}>
            <div style={{ textAlign: 'center', marginBottom: '20px' }}>
              <h3 style={{ margin: '0 0 10px 0', color: '#667eea' }}>VLS Billing Invoice</h3>
              <p style={{ margin: 0, fontSize: '14px', color: '#666' }}>
                Period: {startDate} to {endDate}
              </p>
            </div>

            <div style={{ marginBottom: '20px', fontSize: '14px' }}>
              <strong>Customer Details:</strong><br/>
              {billData.customer?.name}<br/>
              {billData.customer?.phone}<br/>
              {billData.customer?.gstNumber && `GST: ${billData.customer.gstNumber}`}<br/>
              {billData.customer?.address}
            </div>

            {billData.items?.map((dc, dcIndex) => (
              <div key={dcIndex} style={{ marginBottom: '30px', padding: '15px', background: '#f9f9f9', borderRadius: '8px' }}>
                <div style={{ marginBottom: '10px', fontWeight: 'bold', fontSize: '16px', color: '#667eea' }}>
                  DC #{dc.dcNumber} - {dc.totalCylinders} Cylinder(s)
                </div>
                <div style={{ fontSize: '13px', marginBottom: '10px', color: '#666' }}>
                  Delivered: {dc.deliveredDate} | Received: {dc.receivedDate}
                </div>
                
                <table style={{ width: '100%', borderCollapse: 'collapse', fontSize: '13px', marginTop: '10px' }}>
                  <thead>
                    <tr style={{ background: '#667eea', color: 'white' }}>
                      <th style={{ padding: '8px', border: '1px solid #ddd' }}>Cylinder #</th>
                      <th style={{ padding: '8px', border: '1px solid #ddd' }}>Type</th>
                      <th style={{ padding: '8px', border: '1px solid #ddd' }}>Days</th>
                      <th style={{ padding: '8px', border: '1px solid #ddd' }}>Rate/Day</th>
                      <th style={{ padding: '8px', border: '1px solid #ddd' }}>Cost</th>
                    </tr>
                  </thead>
                  <tbody>
                    {dc.cylinders.map((cyl, cylIndex) => (
                      <tr key={cylIndex}>
                        <td style={{ padding: '6px', border: '1px solid #ddd' }}>{cyl.cylinderNumber}</td>
                        <td style={{ padding: '6px', border: '1px solid #ddd' }}>{cyl.cylinderType}</td>
                        <td style={{ padding: '6px', border: '1px solid #ddd', textAlign: 'center' }}>{cyl.days}</td>
                        <td style={{ padding: '6px', border: '1px solid #ddd', textAlign: 'right' }}>₹{cyl.rate}</td>
                        <td style={{ padding: '6px', border: '1px solid #ddd', textAlign: 'right' }}>
                          <input
                            type="number"
                            value={editableCosts[`${dcIndex}-${cylIndex}`] || 0}
                            onChange={(e) => handleCostChange(dcIndex, cylIndex, e.target.value)}
                            style={{
                              width: '80px',
                              padding: '4px',
                              border: '1px solid #667eea',
                              borderRadius: '4px',
                              textAlign: 'right'
                            }}
                          />
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ))}

            <div style={{ textAlign: 'right', fontSize: '18px', fontWeight: 'bold', padding: '15px', background: '#f0f0f0', borderRadius: '8px' }}>
              Total Amount: ₹{calculateTotal()}
            </divtr key={index}>
                    <td style={{ padding: '8px', border: '1px solid #ddd' }}>{item.date}</td>
                    <td style={{ padding: '8px', border: '1px solid #ddd' }}>{item.description}</td>
                    <td style={{ padding: '8px', border: '1px solid #ddd', textAlign: 'center' }}>{item.days}</td>
                    <td style={{ padding: '8px', border: '1px solid #ddd', textAlign: 'right' }}>₹{item.rate}</td>
                    <td style={{ padding: '8px', border: '1px solid #ddd', textAlign: 'right' }}>₹{item.amount}</td>
                  </tr>
                ))}
              </tbody>
              <tfoot>
                <tr style={{ background: '#f5f5f5', fontWeight: 'bold' }}>
                  <td colSpan="4" style={{ padding: '10px', border: '1px solid #ddd', textAlign: 'right' }}>
                    Total Amount:
                  </td>
                  <td style={{ padding: '10px', border: '1px solid #ddd', textAlign: 'right' }}>
                    ₹{billData.total}
                  </td>
                </tr>
              </tfoot>
            </table>

            <button 
              onClick={handlePrint}
              style={{ marginTop: '20px', background: '#4CAF50' }}
            >
              🖨️ Print Bill
            </button>
          </div>
        )}
      </div>
    </div>
  );
}

export default GenerateBill;
